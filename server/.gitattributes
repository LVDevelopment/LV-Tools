# Normalize line endings across platforms
* text=auto eol=lf

# Lua/JS/TS/CSS should always be LF
*.lua text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf

# The compiled UI bundle is committed so the resource runs without a build step.
# Mark it as generated so GitHub collapses diffs and excludes it from language stats.
ui/dist/** linguist-generated=true
